{
    "name": "tpl/shared",
    "description": "Shared package for multiple Laravel apps",
    "type": "library",
    "license": "proprietary",
    "version": "0.1.24",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0"
    },
    "scripts": {
        "test": "pest",
        "format": "pint",
        "format:check": "pint --test"
    },
    "autoload": {
        "psr-4": {
            "Tpl\\Shared\\": "src/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tpl\\Shared\\Tests\\": "tests/",
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tpl\\Shared\\SharedServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
