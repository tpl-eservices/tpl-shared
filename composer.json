{
    "name": "tpl/shared",
    "description": "Shared Laravel package for library systems with BiblioCommons SSO integration",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "bibliocommons", "sso", "library", "authentication"],
    "homepage": "https://github.com/tpl-eservices/tpl-shared",
    "authors": [
        {
            "name": "Toronto Public Library"
        }
    ],
    "version": "0.1.33",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0"
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint",
        "format:check": "pint --test"
    },
    "autoload": {
        "psr-4": {
            "Tpl\\Shared\\": "src/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tpl\\Shared\\Tests\\": "tests/",
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tpl\\Shared\\SharedServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
